{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": []
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=AeroponicIOT;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "JwtSettings": {
    "SecretKey": "",
    "ExpirationMinutes": 1440,
    "Issuer": "AeroponicIOT",
    "Audience": "AeroponicIOT"
  },
  "MqttSettings": {
    "Port": "1883",
    "Host": "localhost"
  },
  "Provisioning": {
    "SharedKey": "",
    "ClaimCodeMinutes": "10"
  },
  "AppUrls": {
    "DashboardBaseUrl": "http://localhost:5062"
  },
  "OnboardingProtection": {
    "FailedAttemptThreshold": 5,
    "FailedAttemptWindowSeconds": 300,
    "FailedAttemptCooldownSeconds": 120,
    "StateTtlSeconds": 900
  },
  "Redis": {
    "Configuration": ""
  },
  "OpenTelemetry": {
    "ServiceName": "AeroponicIOT",
    "Tracing": {
      "SampleRatio": 0.25
    },
    "ExcludedPaths": [
      "/health",
      "/health/live",
      "/health/ready"
    ],
    "Otlp": {
      "Endpoint": ""
    }
  },
  "EmailSettings": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": "587",
    "SmtpUsername": "your-email@gmail.com",
    "SmtpPassword": "",
    "FromEmail": "noreply@smartfarmiot.com",
    "FromName": "Smart Farm IoT System",
    "Enabled": false
  }
}
