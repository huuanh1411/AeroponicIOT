{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "AeroponicIOT": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": []
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=AeroponicIOT;User Id=sa;Password=AeroponicIOT_DB_P@ss123;TrustServerCertificate=True;MultipleActiveResultSets=True"
  },
  "Startup": {
    "ApplyMigrationsOnStartup": true,
    "SeedDefaultCropsOnStartup": true,
    "FailFastOnInitializationError": false
  },
  "PerformanceBudgets": {
    "DashboardLatestP95Ms": 300,
    "SensorIngestP95Ms": 150
  },
  "JwtSettings": {
    "SecretKey": "",
    "ExpirationMinutes": 1440,
    "Issuer": "AeroponicIOT",
    "Audience": "AeroponicIOT"
  },
  "MqttSettings": {
    "Port": 1883,
    "Host": "localhost",
    "Username": "",
    "Password": "",
    "RequireClientAuthentication": true,
    "EnableTls": false,
    "TlsPort": 8883,
    "DisablePlaintextEndpoint": false,
    "ServerCertificatePath": "",
    "ServerCertificatePassword": "",
    "RequireClientCertificate": false,
    "AllowedClientCertificateIssuers": [],
    "AllowedClientCertificateThumbprints": [],
    "EnforceTopicAcl": true,
    "DeviceTopicPrefix": "devices",
    "EnableZigbee2MqttBridge": false,
    "Zigbee2MqttTopicPrefix": "zigbee2mqtt",
    "EnforceZigbeeTopicAcl": true,
    "ZigbeeBridgeUsername": "",
    "ZigbeeBridgeClientId": ""
  },
  "Provisioning": {
    "SharedKey": "",
    "ClaimCodeMinutes": 10
  },
  "AppUrls": {
    "DashboardBaseUrl": "http://localhost:5062"
  },
  "OnboardingProtection": {
    "FailedAttemptThreshold": 5,
    "FailedAttemptWindowSeconds": 300,
    "FailedAttemptCooldownSeconds": 120,
    "StateTtlSeconds": 900
  },
  "Redis": {
    "Configuration": ""
  },
  "OpenTelemetry": {
    "ServiceName": "AeroponicIOT",
    "Tracing": {
      "SampleRatio": 0.25
    },
    "ExcludedPaths": [
      "/health",
      "/health/live",
      "/health/ready"
    ],
    "Otlp": {
      "Endpoint": ""
    }
  },
  "AISuggestions": {
    "Enabled": false,
    "Endpoint": "https://api.openai.com/v1/chat/completions",
    "ApiKey": "",
    "Model": "gpt-4o-mini",
    "MaxTokens": 500,
    "Temperature": 0.3,
    "CooldownMinutes": 60
  },
  "EmailSettings": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "SmtpUsername": "your-email@gmail.com",
    "SmtpPassword": "",
    "FromEmail": "noreply@smartfarmiot.com",
    "FromName": "Smart Farm IoT System",
    "Enabled": false
  }
