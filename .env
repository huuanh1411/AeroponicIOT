# ============================================================
# AeroponicIOT – Docker environment variables
# Fill in all values marked <CHANGE_ME> before running.
# Never commit this file to version control.
# ============================================================

# Full ADO.NET connection string to your existing SQL Server
# Example: Server=192.168.1.10,1433;Database=AeroponicIOT;User Id=sa;Password=yourpw;TrustServerCertificate=True;MultipleActiveResultSets=true
DB_CONNECTION_STRING=Server=14.225.202.137,1433;Database=AeroponicIOT;User Id=sa;Password=ResoSQL123456@;TrustServerCertificate=true;

# JWT signing secret – use a long random string (32+ chars)
JWT_SECRET_KEY=<CHANGE_ME>

# Shared key used by ESP devices for self-registration
PROVISIONING_SHARED_KEY=<CHANGE_ME>

# Email (set EMAIL_ENABLED=true and fill the rest to enable alerts)
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=noreply@smartfarmiot.com
