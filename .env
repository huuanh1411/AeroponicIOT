# ============================================================
# AeroponicIOT – Docker environment variables
# Fill in all values marked <CHANGE_ME> before running.
# Never commit this file to version control.
# ============================================================

# Full ADO.NET connection string — points to the db service defined in docker-compose
DB_CONNECTION_STRING=Server=aeroponiciot-db,1433;Database=AeroponicIOT;User Id=sa;Password=AeroponicIOT_DB_P@ss123;TrustServerCertificate=True;MultipleActiveResultSets=True

# JWT signing secret – use a long random string (32+ chars)
JWT_SECRET_KEY=change-me-to-a-long-random-secret-key-32chars

# Shared key used by ESP devices for self-registration
PROVISIONING_SHARED_KEY=change-me-device-provisioning-key

# MQTT admin credentials — must match EMQX defaults (admin/public)
MQTT_ADMIN_USERNAME=admin
MQTT_ADMIN_PASSWORD=public

# Zigbee2MQTT bridge integration
ZIGBEE2MQTT_ENABLED=false
ZIGBEE2MQTT_TOPIC_PREFIX=zigbee2mqtt
ZIGBEE2MQTT_SERIAL_PORT=/dev/ttyUSB0

# Enforce ACL on Zigbee topic prefix and lock publishing identity
ZIGBEE2MQTT_ENFORCE_TOPIC_ACL=true
ZIGBEE2MQTT_BRIDGE_USERNAME=
ZIGBEE2MQTT_BRIDGE_CLIENT_ID=

# Email (set EMAIL_ENABLED=true and fill the rest to enable alerts)
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=noreply@smartfarmiot.com
